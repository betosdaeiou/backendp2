# ==============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO (BACKEND - SEGUNDO PARCIAL SI2)
# ==============================================================================

# ── BASE DE DATOS (PostgreSQL) ────────────────────────────────────────────────
# URL de conexión a la base de datos PostgreSQL.
# Ejemplo: postgresql://usuario:password@localhost:5432/nombre_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emergencia_db

# ── SEGURIDAD Y JWT ───────────────────────────────────────────────────────────
# Clave secreta para firmar tokens JWT (se recomienda cambiarla en producción)
SECRET_KEY=default-secret-key
# Algoritmo de firma
ALGORITHM=HS256
# Tiempo de expiración del token de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── INTELEGENGIA ARTIFICIAL (Google Gemini) ───────────────────────────────────
# API Key de Google Gemini para el análisis automático de incidentes vehiculares
GEMINI_API_KEY=pon_tu_api_key_aqui

# ── SERVICIO DE CORREO ELECTRÓNICO ──────────────────────────────────────────
# Proveedor de correo: "brevo" o "resend"
EMAIL_PROVIDER=brevo
# API Key de Brevo (si EMAIL_PROVIDER es brevo)
BREVO_API_KEY=
# API Key de Resend (si EMAIL_PROVIDER es resend)
RESEND_API_KEY=
# URL del Frontend para enlaces (ej. restauración de contraseña, confirmación)
FRONTEND_URL=http://localhost:4200
# Correo remitente
EMAIL_FROM=noreply@emergenciavehicular.com
# Nombre del remitente
EMAIL_FROM_NAME="Emergencia Vehicular"

# ── NOTIFICACIONES PUSH (Firebase Cloud Messaging) ────────────────────────────
# Puedes configurar Firebase usando UNA de las siguientes tres opciones:
# Opción 1: Credenciales completas en JSON codificadas en Base64 (ideal para Coolify/Render/etc.)
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Opción 2: String JSON completo del archivo de credenciales
FIREBASE_SERVICE_ACCOUNT_JSON=
# Opción 3: Ruta local al archivo JSON de credenciales (por defecto: firebase-service-account.json)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# ── PASARELA DE PAGOS (Stripe) ────────────────────────────────────────────────
# API Key Secreta de Stripe para procesar los pagos
STRIPE_SECRET_KEY=sk_test_51MockTestKeyForDemoAppNoRealMoney123456789
